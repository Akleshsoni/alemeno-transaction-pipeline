# Copy this to .env and fill in your API keys
# At least one LLM key is required for category classification

# LLM Keys (free tier available)
# Gemini Flash free tier: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI (optional fallback)
OPENAI_API_KEY=

# These are pre-configured for docker-compose — do not change
DATABASE_URL=postgresql+asyncpg://alemeno:alemeno_pass@db:5432/transactions_db
SYNC_DATABASE_URL=postgresql://alemeno:alemeno_pass@db:5432/transactions_db
REDIS_URL=redis://redis:6379/0
